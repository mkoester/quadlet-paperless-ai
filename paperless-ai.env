TZ=Europe/Berlin
PAPERLESS_AI_PORT=3000

# Scan interval (cron expression) — every 30 minutes by default
SCAN_INTERVAL=*/30 * * * *

# Tag a document with this tag to have it processed (leave empty to process all)
TAGS=

# Add an "ai-processed" tag after successful processing
ADD_AI_PROCESSED_TAG=yes
AI_PROCESSED_TAG_NAME=ai-processed
