# Local overrides — values here take precedence over paperless-ai.env.
# Copy to paperless-ai.override.env, fill in required values, then symlink it.

# ---------------------------------------------------------------------------
# Paperless-ngx connection (required)
# ---------------------------------------------------------------------------

# Full URL to the Paperless-ngx API (e.g. http://192.168.1.10:8000/api)
PAPERLESS_API_URL=http://your-paperless-ngx-host:8000/api

# API token from Paperless-ngx (Settings → API → Generate token)
PAPERLESS_API_TOKEN=

# Your Paperless-ngx username
PAPERLESS_USERNAME=admin

# ---------------------------------------------------------------------------
# AI provider — uncomment and fill in ONE section
# ---------------------------------------------------------------------------

# --- Ollama (local, recommended for GPU users) ---
AI_PROVIDER=ollama
OLLAMA_API_URL=http://host.containers.internal:11434
OLLAMA_MODEL=llama3.2

# --- OpenAI ---
#AI_PROVIDER=openai
#OPENAI_API_KEY=sk-...
#OPENAI_MODEL=gpt-4o

# --- Custom / OpenAI-compatible (e.g. DeepSeek, LM Studio) ---
#AI_PROVIDER=custom
#CUSTOM_API_KEY=
#CUSTOM_BASE_URL=https://api.deepseek.com/v1
#CUSTOM_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# Optional overrides
# ---------------------------------------------------------------------------

# Override timezone
#TZ=Europe/Berlin

# Process documents that existed before Paperless AI was installed
#PROCESS_PREDEFINED_DOCUMENTS=no
